{
  "name": "sappeun-api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS API for the Sappeun Flutter app.",
  "license": "UNLICENSED",
  "engines": {
    "node": "20.x",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "gen:mission-seed": "node scripts/gen-mission-seed.mjs",
    "verify:mission-seed": "node scripts/gen-mission-seed.mjs && git diff --exit-code supabase/migrations/0010_mission_content.sql",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@supabase/supabase-js": "^2.105.4",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.5",
    "@types/node": "^20.19.25",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.25.0"
}
